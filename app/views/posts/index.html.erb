<div class="posts-feed">

  <div class="feed-header">

    <h1>Лента</h1>

    <p>Публикации пользователей</p>

  </div>

  <% if @posts.any? %>

    <div class="feed-list">

      <% @posts.each do |post| %>

        <%= render "post", post: post %>

      <% end %>

    </div>

  <% else %>

    <div class="feed-empty">

      <h2>Пока нет публикаций</h2>

      <p>Подпишитесь на пользователей или создайте свой первый пост.</p>

    </div>

  <% end %>

</div>