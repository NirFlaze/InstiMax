<div class="home-layout">

    <aside class="following-sidebar">

        <h3>Подписки</h3>

        <% if current_user.following.any? %>

            <% current_user.following.each do |user| %>

                <%= link_to user_path(user), class: "following-user" do %>

                    <% if user.avatar.attached? %>

                        <%= image_tag user.avatar, class: "following-avatar" %>

                    <% else %>

                        <div class="following-avatar-placeholder">
                            👤
                        </div>

                    <% end %>

                    <span>
                        <%= user.username %>
                    </span>

                <% end %>

            <% end %>

        <% else %>

            <p class="following-empty">
                Пока нет подписок
            </p>

        <% end %>

    </aside>

    <main class="feed">

        <% if @posts.any? %>

            <% @posts.each do |post| %>

                <div class="feed-post">

                  <div class="post-header">

                      <div class="post-author">

                          <% if post.user.avatar.attached? %>

                              <%= image_tag post.user.avatar, class: "post-avatar" %>

                          <% else %>

                              <div class="post-avatar-placeholder">
                                  👤
                              </div>

                          <% end %>

                          <div>

                              <%= link_to post.user.username,
                                          user_path(post.user),
                                          class: "post-username" %>

                              <div class="post-date">
                                  <%= post.created_at.strftime("%d.%m.%Y") %>
                              </div>

                          </div>

                      </div>

                      <% if post.user == current_user %>

                          <div class="post-actions">

                              <%= link_to "✏️", edit_post_path(post) %>

                              <%= link_to "🗑",
                                          post_path(post),
                                          data: {
                                              turbo_method: :delete,
                                              turbo_confirm: "Удалить публикацию?"
                                          } %>

                          </div>

                      <% end %>

                  </div>

                  <% if post.image.attached? %>

                      <%= image_tag post.image, class: "feed-image" %>

                  <% end %>

                  <% if post.caption.present? %>

                      <div class="post-caption">
                          <%= post.caption %>
                      </div>

                  <% end %>

                  <div class="post-footer">

                      ❤️ <%= post.likes.count %>

                      <span>
                          💬 <%= post.comments.count %>
                      </span>

                  </div>

              </div>

            <% end %>

        <% else %>

            <p>В ленте пока нет публикаций.</p>

        <% end %>

    </main>

</div>
