<div class="explore-page">

    <div class="explore-header">
        <h1>Все публикации</h1>
        <p>Публикации пользователей InstiMax</p>
    </div>

    <% if @posts.any? %>

        <div class="explore-grid">

            <% @posts.each do |post| %>

                <%= render "posts/post", post: post %>

            <% end %>

        </div>

    <% else %>

        <div class="explore-empty">

            <h2>Пока нет публикаций</h2>

            <p>Как только пользователи начнут публиковать фотографии, они появятся здесь.</p>

        </div>

    <% end %>

</div>