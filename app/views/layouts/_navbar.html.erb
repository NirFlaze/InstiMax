<header class="navbar">

    <div class="navbar-container">

        <%= link_to root_path, class: "navbar-logo" do %>
            InstiMax
        <% end %>

        <% if user_signed_in? %>

            <div class="navbar-search">

                <%= form_with url: search_path,
                            method: :get,
                            data: {
                                controller: "search",
                                turbo_frame: "search_results"
                            } do |f| %>

                    <%= f.text_field :query,
                        value: @query,
                        placeholder: "Поиск пользователей...",
                        autocomplete: "off",
                        data: {
                            action: "input->search#submit",
                            search_target: "input"
                        } %>

                <% end %>

                <%= turbo_frame_tag "search_results" do %>
                    <%= render "search/results" %>
                <% end %>

            </div>

        <% end %>

        <nav class="navbar-menu">

            <% if user_signed_in? %>

                <%= link_to root_path, class: "nav-link" do %>
                    🏠
                    <span>Главная</span>
                <% end %>

                <%= link_to posts_path, class: "nav-link" do %>
                    🧭
                    <span>Посты</span>
                <% end %>

                <%= link_to new_post_path, class: "btn btn-primary" do %>
                    ➕ Создать пост
                <% end %>

                <%= link_to profile_path, class: "nav-link" do %>
                    👤
                    <span>Профиль</span>
                <% end %>

                <%= link_to destroy_user_session_path,
                            data: { turbo_method: :delete },
                            class: "nav-link" do %>
                    🚪
                    <span>Выйти</span>
                <% end %>

            <% end %>

        </nav>

    </div>

</header>