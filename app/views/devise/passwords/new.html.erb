<div class="devise-container">

    <div class="devise-card">

        <h2>Восстановление пароля</h2>

        <p class="devise-subtitle">
            Введите адрес электронной почты, и мы отправим ссылку для смены пароля.
        </p>

        <%= form_for(resource,
            as: resource_name,
            url: password_path(resource_name),
            html: { method: :post }) do |f| %>

            <%= render "devise/shared/error_messages",
                resource: resource %>

            <div class="field">

                <%= f.label :email, "Электронная почта" %>

                <%= f.email_field :email,
                    autofocus: true,
                    autocomplete: "email" %>

            </div>

            <div class="actions">

                <%= f.submit "Отправить инструкции" %>

            </div>

        <% end %>

        <div class="devise-links">

            <%= render "devise/shared/links" %>

        </div>

    </div>

</div>