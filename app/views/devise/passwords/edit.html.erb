<h2>Сменить пароль</h2>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>
  <%= f.hidden_field :reset_password_token %>

  <div class="field">
    <p><%= f.label :password, "Новый пароль" %></p>
    <% if @minimum_password_length %>
      <p><em>(минимум символов <%= @minimum_password_length %>)</em></p>
    <% end %>
    <p><%= f.password_field :password, autofocus: true, autocomplete: "new-password" %></p>
  </div>

  <div class="field">
    <p><%= f.label :password_confirmation, "Подтвердите новый пароль" %></p>
    <p><%= f.password_field :password_confirmation, autocomplete: "new-password" %></p>
  </div>

  <div class="actions">
    <%= f.submit "Сменить" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
