<div class="devise-container">

    <div class="devise-card">

        <h2>Вход в InstiMax</h2>

        <p class="devise-subtitle">Добро пожаловать!</p>

        <%= form_for(resource,
            as: resource_name,
            url: session_path(resource_name)) do |f| %>

            <div class="field">

                <%= f.label :email, "Электронная почта" %>

                <%= f.email_field :email,
                    autofocus: true,
                    autocomplete: "email" %>

            </div>

            <div class="field">

                <%= f.label :password, "Пароль" %>

                <%= f.password_field :password,
                    autocomplete: "current-password" %>

            </div>

            <% if devise_mapping.rememberable? %>

                <div class="remember-me">

                    <%= f.check_box :remember_me %>

                    <%= f.label :remember_me, "Запомнить меня" %>

                </div>

            <% end %>

            <div class="actions">

                <%= f.submit "Войти" %>

            </div>

        <% end %>

        <div class="devise-links">

            <%= render "devise/shared/links" %>

        </div>

    </div>

</div>