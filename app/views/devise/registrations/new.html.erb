<div class="devise-container">

    <div class="devise-card">

        <h2>Регистрация</h2>

        <p class="devise-subtitle">Создайте аккаунт InstiMax</p>

        <%= form_for(resource,
            as: resource_name,
            url: registration_path(resource_name)) do |f| %>

            <%= render "devise/shared/error_messages",
                resource: resource %>

            <div class="field">

                <%= f.label :username, "Имя пользователя" %>

                <%= f.text_field :username,
                    autofocus: true %>

            </div>

            <div class="field">

                <%= f.label :email, "Электронная почта" %>

                <%= f.email_field :email,
                    autocomplete: "email" %>

            </div>

            <div class="field">

                <%= f.label :password, "Пароль" %>

                <% if @minimum_password_length %>

                    <small>
                        Минимум <%= @minimum_password_length %> символов
                    </small>

                <% end %>

                <%= f.password_field :password,
                    autocomplete: "new-password" %>

            </div>

            <div class="field">

                <%= f.label :password_confirmation,
                    "Подтвердите пароль" %>

                <%= f.password_field :password_confirmation,
                    autocomplete: "new-password" %>

            </div>

            <div class="actions">

                <%= f.submit "Создать аккаунт" %>

            </div>

        <% end %>

        <div class="devise-links">

            <%= render "devise/shared/links" %>

        </div>

    </div>

</div>